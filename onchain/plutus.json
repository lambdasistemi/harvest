    "voucher/types/VoucherAction": {
      "title": "VoucherAction",
      "description": "Unified redeemer for the voucher validator. One validator, one\n address — the variant tag selects the operation.\n\n Plutus Data encoding (inline fields, no nesting):\n   Spend  → Constr 0 [d, commit_spent_new, …, proof]\n   Redeem → Constr 1 [reificator_sig]\n   Revert → Constr 2 [prior_commit_spent, shop_sig]",
      "anyOf": [
        {
          "title": "Spend",
          "description": "Settlement: Groth16 + Ed25519 two-layer authorisation.\n\n `signed_data` canonical byte layout (106 bytes, big-endian):\n   txid        [32 bytes]   raw Cardano TxId of one consumed input\n   ix          [ 2 bytes]   u16 output index\n   acceptor_ax [32 bytes]   acceptor's EdDSA-Jubjub pk x coord\n   acceptor_ay [32 bytes]   acceptor's EdDSA-Jubjub pk y coord\n   d           [ 8 bytes]   spend amount",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "d",
              "description": "The public spend amount",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "commit_spent_new",
              "description": "New Poseidon commitment to updated counter",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "issuer_ax",
              "description": "Issuer's EdDSA public key (x coordinate, Jubjub curve)",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "issuer_ay",
              "description": "Issuer's EdDSA public key (y coordinate, Jubjub curve)",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "pk_c_hi",
              "description": "Customer's Ed25519 public key, high half (first 16 bytes as BE int).",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "pk_c_lo",
              "description": "Customer's Ed25519 public key, low half (last 16 bytes as BE int).",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "customer_pubkey",
              "description": "Customer's Ed25519 public key, 32 bytes.",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "customer_signature",
              "description": "Customer's Ed25519 signature over `signed_data`, 64 bytes.",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "signed_data",
              "description": "Canonical 106-byte payload the customer signed (see layout above).",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "proof",
              "description": "Groth16 proof that the spend is valid",
              "$ref": "#/definitions/voucher~1types~1Groth16Proof"
            }
          ]
        },
        {
          "title": "Redeem",
          "description": "Redemption: reificator destroys the voucher entry.\n\n The reificator signs `own_ref.transaction_id || \"REDEEM\"` (38 bytes)\n under the datum's `reificator_pk`.",
          "dataType": "constructor",
          "index": 1,
          "fields": [
            {
              "title": "reificator_sig",
              "description": "Ed25519 signature (64 bytes) over (txid || \"REDEEM\").",
              "$ref": "#/definitions/ByteArray"
            }
          ]
        },
        {
          "title": "Revert",
          "description": "Revert: shop master rolls back or removes an entry.\n\n The shop master signs `own_ref.transaction_id || \"REVERT\" ||\n prior_commit_spent_bytes` (70 bytes) under the datum's `shop_pk`.\n `prior_commit_spent_bytes` is 32 bytes big-endian zero-padded.",
          "dataType": "constructor",
          "index": 2,
          "fields": [
            {
              "title": "prior_commit_spent",
              "description": "Poseidon commitment to roll back to.",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "shop_sig",
              "description": "Ed25519 signature (64 bytes) over (txid || \"REVERT\" || prior_bytes).",
              "$ref": "#/definitions/ByteArray"
            }
          ]
        }
      ]
    },
    "voucher/types/VoucherDatum": {
      "title": "VoucherDatum",
      "description": "On-chain state per (user, shop, reificator).\n\n The first two fields (`user_id`, `commit_spent`) are wire-compatible\n with the #15 `VoucherDatum`. `shop_pk` and `reificator_pk` are\n frozen at first settlement and preserved by every subsequent\n settlement on this UTxO (see\n `specs/003-devnet-full-flow/contracts/voucher-datum.md`).",
      "anyOf": [
        {
          "title": "VoucherDatum",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "user_id",
              "description": "User identity: Poseidon(user_secret)",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "commit_spent",
              "description": "Poseidon commitment to the running spend total.",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "shop_pk",
              "description": "32-byte Ed25519 pk of the shop that authorised this entry.",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "reificator_pk",
              "description": "32-byte Ed25519 pk of the reificator that submitted the first\n settlement.",
              "$ref": "#/definitions/ByteArray"
            }
          ]
        }
      ]
    }
