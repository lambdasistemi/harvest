            }
          ]
        }
      ]
    },
    "voucher/types/VoucherDatum": {
      "title": "VoucherDatum",
      "description": "On-chain state per (user, shop, reificator).\n\n The first two fields (`user_id`, `commit_spent`) are wire-compatible\n with the #15 `VoucherDatum`. `shop_pk` and `reificator_pk` are\n frozen at first settlement and preserved by every subsequent\n settlement on this UTxO (see\n `specs/003-devnet-full-flow/contracts/voucher-datum.md`).",
      "anyOf": [
        {
          "title": "VoucherDatum",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "user_id",
              "description": "User identity: Poseidon(user_secret)",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "commit_spent",
              "description": "Poseidon commitment to the running spend total.",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "shop_pk",
              "description": "32-byte Ed25519 pk of the shop that authorised this entry.",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "reificator_pk",
              "description": "32-byte Ed25519 pk of the reificator that submitted the first\n settlement.",
              "$ref": "#/definitions/ByteArray"
            }
          ]
        }
      ]
    }
