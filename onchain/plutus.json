              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "c",
              "description": "G1 element (compressed, 48 bytes)",
              "$ref": "#/definitions/ByteArray"
            }
          ]
        }
      ]
    },
    "voucher/types/SpendRedeemer": {
      "title": "SpendRedeemer",
      "description": "Redeemer for a spend transaction.\n\n Per-transaction binding for acceptor_pk, TxOutRef, and d is provided by\n the customer's Ed25519 signature over `signed_data`, verified on-chain\n with the Plutus builtin VerifyEd25519Signature.\n\n `signed_data` canonical byte layout (106 bytes, big-endian):\n   txid        [32 bytes]   raw Cardano TxId of one consumed input\n   ix          [ 2 bytes]   u16 output index\n   acceptor_ax [32 bytes]   acceptor's EdDSA-Jubjub pk x coord\n   acceptor_ay [32 bytes]   acceptor's EdDSA-Jubjub pk y coord\n   d           [ 8 bytes]   spend amount",
      "anyOf": [
        {
          "title": "SpendRedeemer",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "d",
              "description": "The public spend amount",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "commit_spent_new",
              "description": "New Poseidon commitment to updated counter",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "issuer_ax",
              "description": "Issuer's EdDSA public key (x coordinate, Jubjub curve)",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "issuer_ay",
              "description": "Issuer's EdDSA public key (y coordinate, Jubjub curve)",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "pk_c_hi",
              "description": "Customer's Ed25519 public key, high half (first 16 bytes as BE int).\n Matches the corresponding Groth16 public input so the validator can\n cross-check it against `customer_pubkey` below.",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "pk_c_lo",
              "description": "Customer's Ed25519 public key, low half (last 16 bytes as BE int).",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "customer_pubkey",
              "description": "Customer's Ed25519 public key, 32 bytes.",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "customer_signature",
              "description": "Customer's Ed25519 signature over `signed_data`, 64 bytes.",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "signed_data",
              "description": "Canonical 106-byte payload the customer signed (see layout above).",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "proof",
              "description": "Groth16 proof that the spend is valid",
              "$ref": "#/definitions/voucher~1types~1Groth16Proof"
            }
          ]
        }
      ]
    },
