    "harvest/coalition_types/CoalitionDatum": {
      "title": "CoalitionDatum",
      "description": "Coalition-metadata datum and governance redeemer types.\n\n Shapes are authoritative per\n `specs/003-devnet-full-flow/contracts/coalition-metadata-datum.md`.\n Coalition registry UTxO datum.\n\n Both `shop_pks` and `reificator_pks` are canonically sorted\n lexicographically (byte order) and free of duplicates. `issuer_pk`\n is frozen at coalition-create time and preserved by every governance\n transition.",
      "anyOf": [
        {
          "title": "CoalitionDatum",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "shop_pks",
              "description": "Sorted, unique list of 32-byte Ed25519 shop public keys.",
              "$ref": "#/definitions/List<ByteArray>"
            },
            {
              "title": "reificator_pks",
              "description": "Sorted, unique list of 32-byte Ed25519 reificator public keys.",
              "$ref": "#/definitions/List<ByteArray>"
            },
            {
              "title": "issuer_pk",
              "description": "32-byte Ed25519 public key of the coalition issuer.",
              "$ref": "#/definitions/ByteArray"
            }
          ]
        }
      ]
    },
    "harvest/coalition_types/GovernanceRedeemer": {
      "title": "GovernanceRedeemer",
      "description": "Governance redeemer submitted against the coalition-metadata\n validator.\n\n `issuer_sig` is an Ed25519 signature produced by `issuer_pk` over\n the concatenation `txid || op_tag || target_pk`, where `txid` is\n the 32-byte transaction body hash, `op_tag` is a single byte\n (`0x00` = AddShop, `0x01` = AddReificator, `0x02` = RevokeReificator),\n and `target_pk` is the 32-byte key being added or revoked.",
      "anyOf": [
        {
          "title": "AddShop",
          "description": "Add a shop key to `shop_pks`.",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "target_pk",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "issuer_sig",
              "$ref": "#/definitions/ByteArray"
            }
          ]
        },
        {
          "title": "AddReificator",
          "description": "Add a reificator key to `reificator_pks`.",
          "dataType": "constructor",
          "index": 1,
          "fields": [
            {
              "title": "target_pk",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "issuer_sig",
              "$ref": "#/definitions/ByteArray"
            }
          ]
        },
        {
          "title": "RevokeReificator",
          "description": "Remove a reificator key from `reificator_pks`.",
          "dataType": "constructor",
          "index": 2,
          "fields": [
            {
              "title": "target_pk",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "issuer_sig",
              "$ref": "#/definitions/ByteArray"
            }
          ]
        }
      ]
    },
